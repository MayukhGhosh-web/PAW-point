{
  "extends": ["stylelint-config-standard"],
  "plugins": ["stylelint-tailwindcss"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "config",
          "theme",
          "screen",
          "source",
          "import",
          "custom-variant",
          "utility",
          "keyframes"
        ]
      }
    ],
    "function-no-unknown": null,
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["is", "where"]
      }
    ]
  }
}
